{
  "name": "aws-bedrock-quota-dashboard",
  "private": true,
  "scripts": {
    "fetch": "node build/fetch.js",
    "aggregate": "node build/aggregate.js",
    "bundle-sdk": "node build/bundle-sdk.js",
    "copy-assets": "node build/copy-assets.js",
    "stamp": "node build/stamp-version.js",
    "build:site": "npm run bundle-sdk && npm run copy-assets && npm run stamp",
    "build": "npm run fetch && npm run aggregate && npm run build:site"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock": "^3",
    "@aws-sdk/client-bedrock-runtime": "^3",
    "@aws-sdk/client-cloudwatch": "^3",
    "@aws-sdk/client-service-quotas": "^3"
  },
  "devDependencies": {
    "esbuild": "^0.25"
  }
}
